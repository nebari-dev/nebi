{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",

	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},

	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/dist",
			"!wailsjs",
			"!src/components/ui",
			"!**/*.test.tsx"
		]
	},

	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},

	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,

			"correctness": {
				"noUndeclaredVariables": "error",
				"useExhaustiveDependencies": "off",
				"useHookAtTopLevel": "off"
			},

			"style": {
				"useComponentExportOnlyModules": {
					"level": "warn",
					"options": {
						"allowConstantExport": true
					}
				}
			},

			"a11y": {
				"noSvgWithoutTitle": "off",
				"noLabelWithoutControl": "off",
				"useButtonType": "off",
				"noAutofocus": "off"
			},

			"suspicious": {
				"noArrayIndexKey": "off",
				"noExplicitAny": "off",
				"noDuplicateObjectKeys": "off"
			},

			"style": {
				"noNonNullAssertion": "off",
				"useComponentExportOnlyModules": {
					"level": "warn",
					"options": {
						"allowConstantExport": true
					}
				}
			}
		}
	},

	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},

	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},

	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
