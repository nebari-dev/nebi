{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": false,
    "includes": [
      "src/**",
      "biome.json",
      "package.json",
      "tsconfig*.json",
      "vite.config.ts",
      "!!**/dist",
      "!wailsjs",
      "!src/components/ui"
    ]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },

  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",

      "correctness": {
        "noUndeclaredVariables": "error"
      },

      "a11y": {
        "useValidAriaRole": {
          "level": "error",
          "options": {
            "ignoreNonDom": true
          }
        }
      },

      "style": {
        "useComponentExportOnlyModules": {
          "level": "warn",
          "options": {
            "allowConstantExport": true
          }
        }
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },

  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
